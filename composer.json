{
    "name": "avunu/wp-cloud-files",
    "description": "Use S3 object storage for WordPress uploads",
    "type": "library",
    "version": "0.3.2",
    "require": {
        "php": "^8.1",
        "league/flysystem-aws-s3-v3": "~3",
        "aws/aws-sdk-php": "^3.29",
        "phpoffice/phpword": "^1.3",
        "phpoffice/phpspreadsheet": "^3.9",
        "phpoffice/phppresentation": "^1.2",
        "dompdf/dompdf": "^3.1",
        "mpdf/mpdf": "^8.2",
        "yahnis-elsts/plugin-update-checker": "^5.6"
    },
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Avunu LLC",
            "email": "mail@avu.nu"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Avunu\\WPCloudFiles\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "classmap-authoritative": true
    },
    "require-dev": {
        "johnpbloch/wordpress-core": "dev-master"
    }
}
